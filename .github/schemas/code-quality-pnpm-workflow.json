{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow calling code-quality-pnpm reusable workflow",
  "allOf": [
    { "$ref": "https://json.schemastore.org/github-workflow.json" },
    {
      "properties": {
        "jobs": {
          "type": "object",
          "properties": {
            "code-quality": {
              "type": "object",
              "properties": {
                "uses": {
                  "type": "string",
                  "pattern": ".*/code-quality-pnpm.yaml@.*"
                },
                "with": {
                  "type": "object",
                  "properties": {
                    "node-version": { "type": "string" },
                    "pnpm-version": { "type": "string" }
                  },
                  "required": ["node-version", "pnpm-version"],
                  "additionalProperties": false
                }
              },
              "required": ["uses", "with"]
            }
          }
        }
      }
    }
  ]
} 